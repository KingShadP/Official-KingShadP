<!-- Simple Native HTML Decrypted Transmission Sound effect generator -->
<script>
  (function() {
    document.addEventListener('DOMContentLoaded', () => {
      const trigger = document.getElementById('sonic-vault-trigger');
      if (!trigger) return;

      let audioCtx = null;
      let isPlaying = false;
      let gainNode = null;
      let oscNode1 = null;
      let oscNode2 = null;

      // Audio Synthesis Loop
      function startTransmission() {
        if (!audioCtx) {
          // Cross-browser context
          audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        }

        if (audioCtx.state === 'suspended') {
          audioCtx.resume();
        }

        // Beautiful deep continuous cyber synth and mechanical clicking hums
        gainNode = audioCtx.createGain();
        gainNode.gain.setValueAtTime(0.08, audioCtx.currentTime);

        // Low frequency hum tone
        oscNode1 = audioCtx.createOscillator();
        oscNode1.type = 'sawtooth';
        oscNode1.frequency.setValueAtTime(55, audioCtx.currentTime); // A1 hum
        
        // Secondary filtering modulation
        oscNode2 = audioCtx.createOscillator();
        oscNode2.type = 'sine';
        oscNode2.frequency.setValueAtTime(110, audioCtx.currentTime); // A2 filter overtone

        // Low Pass Filter for ultra-warm velvet atmosphere
        const filter = audioCtx.createBiquadFilter();
        filter.type = 'lowpass';
        filter.frequency.setValueAtTime(180, audioCtx.currentTime);

        // Connect modules
        oscNode1.connect(filter);
        oscNode2.connect(filter);
        filter.connect(gainNode);
        gainNode.connect(audioCtx.destination);

        oscNode1.start();
        oscNode2.start();

        // Animate visual synthesizer lines dynamically
        const bars = document.querySelectorAll('.divine-vis-bar');
        bars.forEach(bar => {
          bar.style.animation = 'divine-bar-bounce 0.8s ease-in-out infinite alternate';
          bar.style.animationDelay = bar.style.getPropertyValue('--d');
        });

        isPlaying = true;
      }

      function stopTransmission() {
        if (oscNode1) {
          try { oscNode1.stop(); } catch(e){}
        }
        if (oscNode2) {
          try { oscNode2.stop(); } catch(e){}
        }
        
        const bars = document.querySelectorAll('.divine-vis-bar');
        bars.forEach(bar => {
          bar.style.animation = 'none';
        });

        isPlaying = false;
      }

      trigger.addEventListener('click', () => {
        if (!isPlaying) {
          startTransmission();
          trigger.classList.add('border-gold/60');
          trigger.querySelector('span:last-child').innerText = '[ TRANSMISSION ONLINE ]';
          trigger.querySelector('span:last-child').classList.remove('animate-pulse');
          trigger.querySelector('span:last-child').classList.add('text-gold');
        } else {
          stopTransmission();
          trigger.classList.remove('border-gold/60');
          trigger.querySelector('span:last-child').innerText = '[ TOGGLE TRANSMISSION ]';
          trigger.querySelector('span:last-child').classList.add('animate-pulse');
          trigger.querySelector('span:last-child').classList.remove('text-gold');
        }
      });
    });
  })();
</script>

<style>
  /* Audio visualizer bar animations */
  @keyframes divine-bar-bounce {
    0% { height: 15%; }
    100% { height: 100%; }
  }
  .divine-vis-bar {
    transform-origin: bottom;
    transition: height 0.1s ease;
  }
</style>
