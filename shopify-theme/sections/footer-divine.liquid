{% schema %}
{
  "name": "Divine Footer",
  "tag": "footer",
  "class": "section-footer-divine",
  "settings": [
    {
      "type": "text",
      "id": "branding_title",
      "label": "Footer Logo Branding",
      "default": "KingShadP"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "Sovereign Architecture // All Rights Reserved"
    },
    {
      "type": "text",
      "id": "system_status_lbl",
      "label": "System Status string",
      "default": "Sys.Online"
    },
    {
      "type": "text",
      "id": "firmware_version",
      "label": "System Version",
      "default": "v9.0.01"
    }
  ]
}
{% endschema %}

<div class="w-full py-12 px-6 lg:px-24 border-t border-ivory/10 z-10 bg-void relative">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
    <div class="flex flex-col gap-2">
      <span class="font-serif text-2xl italic font-light text-ivory/80">
        {{ section.settings.branding_title }}<span class="text-oxblood font-normal font-sans">.</span>
      </span>
      <span class="font-mono text-[8px] uppercase tracking-[0.3em] text-ivory/30">
        {{ section.settings.copyright_text }}
      </span>
    </div>
    
    <div class="flex items-center gap-6 font-mono text-[9px] uppercase tracking-[0.4em] text-ivory/40">
      <div class="flex items-center gap-4">
        <!-- Review Awards A -> SVG -->
        <a href="#" aria-label="Read our Awwwards review" class="text-ivory/40 hover:text-gold transition-colors focus:outline-none focus:ring-2 focus:ring-gold p-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block align-middle"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
        </a>
        <!-- Star Rating FWA -> SVG -->
        <a href="#" aria-label="View FWA site of the day" class="text-ivory/40 hover:text-gold transition-colors focus:outline-none focus:ring-2 focus:ring-gold p-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block align-middle"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </a>
      </div>
      <!-- Status Light & pulse -->
      <div class="flex items-center gap-2">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-gold opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-gold"></span>
        </span>
        <span>{{ section.settings.system_status_lbl }}</span>
      </div>
      <span class="w-[1px] h-3 bg-ivory/20"></span>
      <span>{{ section.settings.firmware_version }}</span>
    </div>
  </div>
</div>
