{% schema %}
{
  "name": "KSP Acquisition Vault",
  "tag": "section",
  "class": "ksp-acquisition-section",
  "settings": [
    {
      "type": "text",
      "id": "code",
      "label": "Protocol System Code",
      "default": "SYSTEM_ACQ_V.01"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Tactile Acquisition Protocol"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "AUTHENTICATED DROPS & SECURE SIGNALS"
    },
    {
      "type": "textarea",
      "id": "drop_pretext",
      "label": "Drop Warning Legend",
      "default": "Entering the private buying protocol. Standard commercial loops are disrupted. Credentials and verification are required to unlock limited orbital physical releases."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Acquisition FAQ Ledger",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Protocol Inquiry (Question)",
          "default": "How are garments authenticated?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Directive Declaration (Answer)",
          "default": "Each garment contains woven aerospace telemetry tag details, cryptographic proof files, and specific latitude/longitude stamps identifying origin genesis."
        }
      ]
    }
  ]
}
{% endschema %}

<section class="relative w-full py-20 px-6 lg:px-24 z-10 bg-transparent overflow-hidden" id="acquisition-vault-room">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
    
    <!-- Left Column: Acquisition Registry Form & Warnings -->
    <div class="lg:col-span-7 flex flex-col gap-8">
      
      <!-- Headers -->
      <div class="border-b border-ivory/10 pb-6">
        <div class="font-mono text-[9px] text-gold uppercase tracking-[0.3em] mb-4">{{ section.settings.subheading }}</div>
        <h2 class="font-serif text-4xl lg:text-5xl text-ivory font-light scramble-text">{{ section.settings.heading }}</h2>
      </div>

      <!-- Warnings -->
      <div class="ruby-glass p-8 border-grid-box border-l-4 border-l-oxblood relative">
        <div class="font-mono text-[9px] text-oxblood uppercase tracking-wider mb-2 font-bold">[ CRITICAL SECURITY CLEARANCE BRIEFING ]</div>
        <p class="font-mono text-[11px] text-ivory/80 leading-relaxed uppercase">{{ section.settings.drop_pretext }}</p>
      </div>

      <!-- Access Form -->
      <div class="ruby-glass p-8 border-grid-box relative">
        <div class="absolute -top-3 left-6 font-mono text-[9px] text-gold tracking-widest px-2 bg-void uppercase">// Drop Queue Registry</div>
        
        <h3 class="font-serif text-2xl font-light text-ivory mb-2 mt-2">Request Credentials</h3>
        <p class="font-mono text-[10px] text-ivory/50 leading-relaxed mb-6 uppercase">SECURE PASSCODE WILL BE DISPATCHED VIA ENCRYPTED ROUTE</p>

        {% form 'customer', class: 'flex flex-col gap-4 font-mono text-xs' %}
          {% if form.posted_successfully? %}
            <div class="font-mono text-xs text-gold border border-gold/30 bg-gold/5 p-4 uppercase mb-4">
              [ SECURE_ACCESS_GRANTED_CHECK_INBOX ]
            </div>
          {% endif %}
          
          <input type="hidden" name="contact[tags]" value="newsletter,vault_access">
          
          <div class="flex flex-col md:flex-row gap-4">
            <div class="flex flex-col gap-2 flex-grow">
              <label for="acq-first-name" class="text-ivory/50 tracking-wider text-[9px] uppercase">COGNOMEN IDENTIFIER (NAME)</label>
              <input type="text" id="acq-first-name" name="contact[first_name]" placeholder="FIRST INITIAL or NAME" class="bg-void/80 border border-ivory/10 px-4 py-3 text-ivory focus:border-gold outline-none w-full">
            </div>
            
            <div class="flex flex-col gap-2 flex-grow">
              <label for="acq-email" class="text-ivory/50 tracking-wider text-[9px] uppercase">ENDPOINT COORDINATES (EMAIL)</label>
              <input type="email" id="acq-email" name="contact[email]" required placeholder="NAME@DOMAIN.SYSTEM" class="bg-void/80 border border-ivory/10 px-4 py-3 text-ivory focus:border-gold outline-none w-full">
            </div>
          </div>

          <button type="submit" class="border border-gold/30 hover:bg-gold/10 text-gold py-4 px-6 tracking-widest uppercase transition-colors text-[10px] w-full mt-4 bg-transparent cursor-pointer">
            [ REGISTER_SIGNAL_EMISSION ]
          </button>
        {% endform %}
      </div>

    </div>

    <!-- Right Column: Systemic FAQ details & parameters -->
    <div class="lg:col-span-5 flex flex-col gap-8 md:mt-8">
      
      <div class="ruby-glass p-8 border-grid-box relative">
        <div class="absolute -top-3 left-6 font-mono text-[9px] text-oxblood tracking-widest px-2 bg-void uppercase">// Reference FAQs</div>
        <div class="font-mono text-[9px] text-gold uppercase tracking-[0.3em] mb-6 mt-2">Core Operations FAQ</div>
        
        <div class="flex flex-col divide-y divide-ivory/10" id="accordion-acquisition-parent">
          {% for block in section.blocks %}
            {% if block.type == 'faq' %}
              <details class="py-4 font-mono group cursor-pointer transition-all duration-300">
                <summary class="flex justify-between items-center text-xs tracking-wider text-ivory list-none group-open:text-gold">
                  <span class="flex items-center gap-3">
                    <span class="text-oxblood">//</span> {{ block.settings.question }}
                  </span>
                  <span class="text-[10px] transition-transform duration-300 group-open:rotate-180">▼</span>
                </summary>
                <p class="mt-4 text-[10px] leading-relaxed text-ivory/60 uppercase tracking-normal pl-6">
                  {{ block.settings.answer }}
                </p>
              </details>
            {% endif %}
          {% endfor %}
        </div>
      </div>

    </div>

  </div>
</section>
